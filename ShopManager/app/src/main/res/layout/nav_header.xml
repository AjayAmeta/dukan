<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="180dp"
    android:background="@color/colorPrimary"
    android:gravity="bottom" android:orientation="vertical" android:padding="20dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🏪" android:textSize="40sp" />
    <TextView android:id="@+id/tvHeaderShopName"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Shop Name" android:textColor="@color/white"
        android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
    <TextView android:id="@+id/tvHeaderShopType"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Shop Type" android:textColor="#CCffffff" android:textSize="13sp"/>
</LinearLayout>
